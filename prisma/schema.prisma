generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  ARTISAN
  ADMIN
}

enum MissionStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  VALIDATED
  DISPUTED
  CANCELLED
}

enum PaymentStatus {
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

enum DocumentType {
  SIRET
  DECENNALE
  IDENTITY
  RGE
  QUALIBAT
  KBIS
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  passwordHash  String?
  role          UserRole  @default(CLIENT)
  avatar        String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  artisanProfile ArtisanProfile?
  clientMissions Mission[]       @relation("ClientMissions")
  reviews        Review[]
  accounts       Account[]
  sessions       Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ArtisanProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String?
  siret       String?
  description String?
  specialties String[]
  city        String?
  postalCode  String?
  latitude    Float?
  longitude   Float?
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  verified    Boolean  @default(false)
  stripeAccountId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]
  missions  Mission[]  @relation("ArtisanMissions")
  reviews   Review[]

  @@map("artisan_profiles")
}

model Document {
  id               String       @id @default(cuid())
  artisanProfileId String
  type             DocumentType
  fileUrl          String
  fileName         String
  verified         Boolean      @default(false)
  expiresAt        DateTime?
  createdAt        DateTime     @default(now())

  artisanProfile ArtisanProfile @relation(fields: [artisanProfileId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Mission {
  id          String        @id @default(cuid())
  clientId    String
  artisanId   String
  title       String
  description String?
  category    String
  address     String?
  status      MissionStatus @default(PENDING)
  amount      Float?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  client  User           @relation("ClientMissions", fields: [clientId], references: [id])
  artisan ArtisanProfile @relation("ArtisanMissions", fields: [artisanId], references: [id])
  payment Payment?
  review  Review?

  @@map("missions")
}

model Payment {
  id              String        @id @default(cuid())
  missionId       String        @unique
  amount          Float
  commission      Float
  status          PaymentStatus @default(HELD)
  stripePaymentId String?
  paidAt          DateTime?
  releasedAt      DateTime?
  createdAt       DateTime      @default(now())

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Review {
  id               String   @id @default(cuid())
  missionId        String   @unique
  userId           String
  artisanProfileId String
  rating           Int
  comment          String?
  createdAt        DateTime @default(now())

  mission        Mission        @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id])
  artisanProfile ArtisanProfile @relation(fields: [artisanProfileId], references: [id])

  @@map("reviews")
}
